# Environment Variables Template
# Copy this file to .env.local and fill in your values

# OpenRouter API Key (Required for AI Chatbot)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Resend API Key (Required for Contact Form)
# Get your API key from: https://resend.com/api-keys
# Note: Use onboarding@resend.dev for testing, or add your verified domain
RESEND_API_KEY=your_resend_api_key_here

# GitHub Personal Access Token (Optional - Improves API Rate Limits)
# Without token: 60 requests/hour per IP
# With token: 5000 requests/hour
# Create a token at: https://github.com/settings/tokens
# Required scopes: public_repo (or leave blank for basic read access)
GITHUB_TOKEN=your_github_personal_access_token_here
